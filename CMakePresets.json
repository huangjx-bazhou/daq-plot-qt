        "x64",
        "msvc-static"
      ]
    },
    {
      "name": "v143-x64-release-static",
      "inherits": [
        "common",
        "v143",
        "x64",
        "msvc-static"
      ]
    },
    {
      "name": "v145-x86-debug",
      "inherits": [
        "common",
        "v145",
        "x86",
        "msvc-shared"
      ]
    },
    {
      "name": "v145-x86-release",
      "inherits": [
        "common",
        "v145",
        "x86",
        "msvc-shared"
      ]
    },
    {
      "name": "v145-x64-debug",
      "inherits": [
        "common",
        "v145",
        "x64",
        "msvc-shared"
      ]
    },
    {
      "name": "v145-x64-release",
      "inherits": [
        "common",
        "v145",
        "x64",
        "msvc-shared"
      ]
    },
    {
      "name": "v145-x86-debug-static",
      "inherits": [
        "common",
        "v145",
        "x86",
        "msvc-static"
      ]
    },
    {
      "name": "v145-x86-release-static",
      "inherits": [
        "common",
        "v145",
        "x86",
        "msvc-static"
      ]
    },
    {
      "name": "v145-x64-debug-static",
      "inherits": [
        "common",
        "v145",
        "x64",
        "msvc-static"
      ]
    },
    {
      "name": "v145-x64-release-static",
      "inherits": [
        "common",
        "v145",
        "x64",
        "msvc-static"
      ]
    }
  ],
