{
  "version": 9,
  "cmakeMinimumRequired": {
    "major": 4,
    "minor": 2,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "common",
      "hidden": true,
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "displayName": "${presetName}",
      "cacheVariables": {
        "CMAKE_INSTALL_PREFIX": {
          "type": "PATH",
          "value": "${sourceDir}/out/install/${presetName}"
        }
      }
    },
    {
      "name": "c++",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_CXX_EXTENSIONS": {
          "type": "BOOL",
          "value": "OFF"
        },
        "CMAKE_CXX_STANDARD_REQUIRED": {
          "type": "BOOL",
          "value": "ON"
        }
      }
    },
    {
      "name": "c++11",
      "hidden": true,
      "inherits": [
        "c++"
      ],
      "cacheVariables": {
        "CMAKE_CXX_STANDARD": {
          "type": "STRING",
          "value": "11"
        }
      }
    },
    {
      "name": "c++14",
      "hidden": true,
      "inherits": [
        "c++"
      ],
      "cacheVariables": {
        "CMAKE_CXX_STANDARD": {
          "type": "STRING",
          "value": "14"
        }
      }
    },
    {
      "name": "c++17",
      "hidden": true,
      "inherits": [
        "c++"
      ],
      "cacheVariables": {
        "CMAKE_CXX_STANDARD": {
          "type": "STRING",
          "value": "17"
        }
      }
    },
    {
      "name": "c++20",
      "hidden": true,
      "inherits": [
        "c++"
      ],
      "cacheVariables": {
        "CMAKE_CXX_STANDARD": {
          "type": "STRING",
          "value": "20"
        }
      }
    },
    {
      "name": "v143",
      "hidden": true,
      "inherits": [
        "c++20"
      ],
      "generator": "Visual Studio 17 2022",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "v145",
      "hidden": true,
      "inherits": [
        "c++20"
      ],
      "generator": "Visual Studio 18 2026",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "x86",
      "hidden": true,
      "toolset": "host=x86",
      "architecture": "Win32"
    },
    {
      "name": "x64",
      "hidden": true,
      "toolset": "host=x64",
      "architecture": "x64"
    },
    {
      "name": "static",
      "hidden": true,
      "cacheVariables": {
        "BUILD_SHARED_LIBS": {
          "type": "BOOL",
          "value": "OFF"
        }
      }
    },
    {
      "name": "msvc-static",
      "hidden": true,
      "inherits": [
        "static"
      ],
      "cacheVariables": {
        "CMAKE_MSVC_RUNTIME_LIBRARY": {
          "type": "STRING",
          "value": "MultiThreaded$<$<CONFIG:Debug>:Debug>"
        }
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "shared",
      "hidden": true,
      "cacheVariables": {
        "BUILD_SHARED_LIBS": {
          "type": "BOOL",
          "value": "ON"
        }
      }
    },
    {
      "name": "msvc-shared",
      "hidden": true,
      "inherits": [
        "shared"
      ],
      "cacheVariables": {
        "CMAKE_MSVC_RUNTIME_LIBRARY": {
          "type": "STRING",
          "value": "MultiThreaded$<$<CONFIG:Debug>:Debug>DLL"
        }
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "v143-x86-debug",
      "inherits": [
        "common",
        "v143",
        "x86",
        "msvc-shared"
      ]
    },
    {
      "name": "v143-x86-release",
      "inherits": [
        "common",
        "v143",
        "x86",
        "msvc-shared"
      ]
    },
    {
      "name": "v143-x64-debug",
      "inherits": [
        "common",
        "v143",
        "x64",
        "msvc-shared"
      ]
    },
    {
      "name": "v143-x64-release",
      "inherits": [
        "common",
        "v143",
        "x64",
        "msvc-shared"
      ]
    },
    {
      "name": "v143-x86-debug-static",
      "inherits": [
        "common",
        "v143",
        "x86",
        "msvc-static"
      ]
    },
    {
      "name": "v143-x86-release-static",
      "inherits": [
